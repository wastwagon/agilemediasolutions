# Copy to .env and adjust. Docker Compose reads this automatically.

# --- Local Docker Desktop (compose) ---
FRONTEND_PORT=8085
BACKEND_PORT=4000
BACKEND_EXT_PORT=4005

NEXT_PUBLIC_SITE_NAME=Agile Media Solutions

# Public site URL (no trailing slash). Set to your live domain for correct Open Graph, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://agile-media.com

# Browser → frontend → Next rewrites: must reach the backend service from inside the frontend container.
# Default matches service name `backend` in docker-compose.yml. On Coolify, use the internal hostname:port Coolify assigns if different.
BACKEND_INTERNAL_URL=http://backend:4000

NODE_ENV=production

# Public URL of the frontend (no trailing slash). Required for CORS on the API.
# Coolify: set this to your live site URL, e.g. https://your-domain.com
CORS_ORIGIN=http://localhost:8085

# Postgres
POSTGRES_DB=agile_db
POSTGRES_USER=agile_user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_EXT_PORT=11200

REDIS_EXT_PORT=11201

# Backend ↔ Postgres/Redis (defaults work with compose service names)
# Must use the SAME password as POSTGRES_PASSWORD above when using bundled Postgres.
# In Docker Compose, if you omit DATABASE_URL, it is built from POSTGRES_* automatically.
DATABASE_URL=postgres://agile_user:change-me-in-production@postgres:5432/agile_db
REDIS_URL=redis://redis:6379

# Admin migrations from browser (optional override when API is not rewritten)
# NEXT_PUBLIC_API_URL=http://localhost:4005

# Sign JWT for admin — set a long random string in production (Coolify runtime variable required)
JWT_SECRET=change-me-to-a-long-random-secret

# Local dev convenience only. Production ignores this flag for safety.
SEED_DEFAULT_ADMIN=false

# Login hardening (rate limit + temporary lockout).
LOGIN_WINDOW_MS=900000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MS=900000

# Optional media upload max size in bytes (default 10485760 = 10MB)
MAX_UPLOAD_SIZE_BYTES=10485760
# Hero / CMS video uploads (MP4, WebM). Default 50MB.
MAX_VIDEO_UPLOAD_SIZE_BYTES=52428800
