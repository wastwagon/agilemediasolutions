# Agile Media Solutions Configuration — Example

# Frontend Service
FRONTEND_PORT=8085
NEXT_PUBLIC_SITE_NAME=Agile Media Solutions

# Backend Service
BACKEND_PORT=4000
BACKEND_EXT_PORT=4005
NODE_ENV=production
CORS_ORIGIN=http://localhost:8085

# Database (Production)
POSTGRES_DB=agile_db
POSTGRES_USER=agile_user
POSTGRES_PASSWORD=agile_password
POSTGRES_EXT_PORT=11200

# Redis
REDIS_EXT_PORT=11201
REDIS_URL=redis://redis:6379
